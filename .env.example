# ─────────────────────────────────────────────────────────────────────────────
# ArcGIS Online – OAuth 2.0 Client ID
#   1. Sign in to https://developers.arcgis.com
#   2. Create a new "OAuth 2.0" application.
#   3. Add the following redirect URI:  http://localhost:5173
#   4. Copy the Client ID here.
# ─────────────────────────────────────────────────────────────────────────────
ARCGIS_CLIENT_ID=YOUR_ARCGIS_CLIENT_ID_HERE

# ─────────────────────────────────────────────────────────────────────────────
# ArcGIS Portal URL  (leave as-is for ArcGIS Online)
# ─────────────────────────────────────────────────────────────────────────────
PORTAL_URL=https://www.arcgis.com

# ─────────────────────────────────────────────────────────────────────────────
# Backend Express server port
# ─────────────────────────────────────────────────────────────────────────────
SERVER_PORT=3001
